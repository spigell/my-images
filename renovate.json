{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>spigell/my-renovate",
    "github>spigell/my-renovate//presets/dockerfile-managers",
    "github>spigell/my-renovate//presets/workflow-managers"
  ],
  "commitMessageExtra": "",

  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": ["/ghcr.io/spigell/*/"]
    },
    {
      "matchDepNames": [
        "/^antigravity-cli-/"
      ],
      "groupName": "antigravity-cli"
    },
    {
      "matchDepNames": ["spigell-codex-binary"],
      "extractVersion": "^rust-(?<version>v\\d+\\.\\d+\\.\\d+)$",
      "versioning": "semver-coerced",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchPackageNames": ["linuxserver/openssh-server"],
      "versioning": "regex:^version-(?<major>\\d+)\\.(?<minor>\\d+)_p(?<patch>\\d+)-r(?<build>\\d+)$"
    },
    {
      "matchDepNames": [
        "python",
        "node",
        "go",
        "golangci/golangci-lint",
        "go-delve/delve",
        "yarnpkg/yarn",
        "mikefarah/yq",
        "sparfenyuk/mcp-proxy",
        "sonirico/mcp-shell"
      ],
      "groupName": "universal-workbench",
      "branchPrefix": "renovate/",
      "branchTopic": "universal-workbench-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "kubernetes/kubernetes",
        "helm/helm",
        "derailed/k9s",
        "siderolabs/talos",
        "etcd-io/etcd",
        "kubernetes-sigs/krew",
        "tohjustin/kube-lineage",
        "HolmesGPT/holmesgpt",
        "argoproj/argo-cd",
        "google-cloud-sdk"
      ],
      "groupName": "debug-sre-workbench",
      "branchPrefix": "renovate/",
      "branchTopic": "debug-sre-workbench-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "pulumi/pulumi",
        "pulumi/pulumictl",
        "@pulumi/mcp-server",
        "hashicorp/packer",
        "gruntwork-io/terragrunt",
        "tofuutils/tenv"
      ],
      "groupName": "infra-workbenches",
      "branchPrefix": "renovate/",
      "branchTopic": "infra-workbenches-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": ["debian", "ubuntu", "golang", "alpine", "lsiobase/kasmvnc"],
      "matchDatasources": ["docker"],
      "groupName": "base-os-images",
      "branchPrefix": "renovate/",
      "branchTopic": "base-os-images",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "github/github-mcp-server",
        "ansible/vscode-ansible",
        "tavily-mcp",
        "notebooklm-mcp-cli"
      ],
      "automerge": false,
      "groupName": "mcp-servers",
      "branchPrefix": "renovate/",
      "branchTopic": "mcp-servers-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "spigell-codex-binary",
        "github/spec-kit",
        "@anthropic-ai/claude-code",
        "@anthropic-ai/sandbox-runtime",
        "@qwen-code/qwen-code",
        "@google/gemini-cli",
        "@google/jules",
        "google-antigravity/antigravity-cli"
      ],
      "automerge": false,
      "groupName": "agent-workbenches",
      "branchPrefix": "renovate/",
      "branchTopic": "agent-workbenches-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": ["actions/runner"],
      "groupName": "github-runners",
      "branchTopic": "github-runners-deps"
    }
  ]
}
