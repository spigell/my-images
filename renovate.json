{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>spigell/my-renovate",
    "github>spigell/my-renovate//presets/dockerfile-managers",
    "github>spigell/my-renovate//presets/workflow-managers"
  ],
  "customDatasources": {
    "agy-version": {
      "defaultRegistryUrlTemplate": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/{{{packageName}}}.json",
      "transformTemplates": [
        "{ \"releases\": [ { \"version\": version } ] }"
      ]
    },
    "agy-url": {
      "defaultRegistryUrlTemplate": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/{{{packageName}}}.json",
      "transformTemplates": [
        "{ \"releases\": [ { \"version\": url } ] }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update agy version in Dockerfile",
      "managerFilePatterns": [
        "/(^|/)agy-docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG AGY_VERSION=(?<currentValue>.*)"
      ],
      "depNameTemplate": "antigravity-cli-version",
      "packageNameTemplate": "linux_amd64",
      "datasourceTemplate": "custom.agy-version",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update agy amd64 url in Dockerfile",
      "managerFilePatterns": [
        "/(^|/)agy-docker/Dockerfile$/"
      ],
      "matchStrings": [
        "ARG AGY_LINUX_AMD64_URL=(?<currentValue>[^\\s'\"]+)"
      ],
      "depNameTemplate": "antigravity-cli-amd64-url",
      "packageNameTemplate": "linux_amd64",
      "datasourceTemplate": "custom.agy-url",
      "versioningTemplate": "regex:^https://[^/]+/antigravity-public/antigravity-cli/(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<build>\\d+)/.*$"
    },
    {
      "customType": "regex",
      "description": "Update agy version in publish workflow",
      "managerFilePatterns": [
        "/^\\.github/workflows/agy-publish\\.yaml$/"
      ],
      "matchStrings": [
        "version: v(?<currentValue>.*)"
      ],
      "depNameTemplate": "antigravity-cli-version",
      "packageNameTemplate": "linux_amd64",
      "datasourceTemplate": "custom.agy-version",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": ["/ghcr.io/spigell/*/"]
    },
    {
      "matchDepNames": [
        "/^antigravity-cli-/"
      ],
      "groupName": "antigravity-cli"
    },
    {
      "matchDepNames": ["spigell-codex-binary"],
      "extractVersion": "^rust-(?<version>v\\d+\\.\\d+\\.\\d+)$",
      "versioning": "semver-coerced"
    },
    {
      "matchPackageNames": ["linuxserver/openssh-server"],
      "versioning": "regex:^version-(?<major>\\d+)\\.(?<minor>\\d+)_p(?<patch>\\d+)-r(?<build>\\d+)$"
    },
    {
      "matchDepNames": [
        "python",
        "node",
        "go",
        "golangci/golangci-lint",
        "go-delve/delve",
        "yarnpkg/yarn",
        "mikefarah/yq",
        "sparfenyuk/mcp-proxy",
        "sonirico/mcp-shell"
      ],
      "groupName": "universal-workbench",
      "branchPrefix": "renovate/",
      "branchTopic": "universal-workbench-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "kubernetes/kubernetes",
        "helm/helm",
        "derailed/k9s",
        "siderolabs/talos",
        "etcd-io/etcd",
        "kubernetes-sigs/krew",
        "tohjustin/kube-lineage",
        "HolmesGPT/holmesgpt",
        "argoproj/argo-cd",
        "google-cloud-sdk"
      ],
      "groupName": "debug-sre-workbench",
      "branchPrefix": "renovate/",
      "branchTopic": "debug-sre-workbench-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "pulumi/pulumi",
        "pulumi/pulumictl",
        "@pulumi/mcp-server",
        "hashicorp/packer",
        "gruntwork-io/terragrunt",
        "tofuutils/tenv"
      ],
      "groupName": "infra-workbenches",
      "branchPrefix": "renovate/",
      "branchTopic": "infra-workbenches-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": ["debian", "ubuntu", "golang", "alpine", "lsiobase/kasmvnc"],
      "matchDatasources": ["docker"],
      "groupName": "base-os-images",
      "branchPrefix": "renovate/",
      "branchTopic": "base-os-images",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "github/github-mcp-server",
        "ansible/vscode-ansible",
        "tavily-mcp",
        "notebooklm-mcp-cli"
      ],
      "groupName": "mcp-servers",
      "branchPrefix": "renovate/",
      "branchTopic": "mcp-servers-deps",
      "schedule": ["before 4am on Saturday"]
    },
    {
      "matchDepNames": [
        "github/spec-kit",
        "@anthropic-ai/claude-code",
        "@anthropic-ai/sandbox-runtime",
        "@qwen-code/qwen-code",
        "@google/gemini-cli",
        "@google/jules",
        "spigell-codex-binary"
      ],
      "groupName": "agent-workbenches",
      "branchPrefix": "renovate/",
      "branchTopic": "agent-workbenches-deps",
      "schedule": ["before 4am on Saturday"]
    }
  ]
}
