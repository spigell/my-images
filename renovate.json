{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "branchPrefix": "renovate/chore/",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    "group:monorepos",
    "group:recommended",
    "mergeConfidence:all-badges"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies", "renovate"],
  "gitAuthor": "github-actions[bot] <41898282+github-actions[bot]@users.noreply.github.com>",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions updates"
    },
    {
      "matchPackagePatterns": ["ghcr.io/spigell/*"],
      "enabled": false
    },
    {
      "description": "Don't update golang in FROM lines, we use ARG instead",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["golang"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customManagerName": "Custom Dockerfile Manager",
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "ARG\\s+(?<depName>[^\\s=]+)_VERSION=(?<currentValue>[^\\s]+)\\s+#\\s+renovate:\\s+datasource=(?<datasource>[^\\s]+)\\s+depName=(?<packageName>[^\\s]+)(?:\\s+versioning=(?<versioning>[^\\s]+))?\\n",
        "ARG\\s+(?<depName>[^\\s=]+)_REF=(?<currentValue>[^\\s]+)\\s+#\\s+renovate:\\s+datasource=(?<datasource>[^\\s]+)\\s+depName=(?<packageName>[^\\s]+)(?:\\s+versioning=(?<versioning>[^\\s]+))?\\n"
      ]
    }
  ]
}
